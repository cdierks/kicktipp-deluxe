# ── Abhängigkeiten ──────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ─────────────────────────────────────────────
/.next/
/out/
/build

# ── Prisma ──────────────────────────────────────────────
# Generierter Client (wird per postinstall neu erzeugt)
/src/generated/prisma
# SQLite-Datenbank (lokal, nicht ins Repo)
prisma/*.db
prisma/*.db-journal

# ── Umgebungsvariablen ───────────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Tests / Coverage ─────────────────────────────────────
/coverage

# ── TypeScript ───────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Editor / OS ──────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db

# ── Logs ────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Deployment ───────────────────────────────────────────
.vercel

# ── Claude Code (lokale KI-Assistent-Einstellungen) ──────
.claude/
